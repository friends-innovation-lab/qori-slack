{
  "type": "modal",
  "callback_id": "research_plan",
  "title": {
    "type": "plain_text",
    "text": "Research plan"
  },
  "submit": {
    "type": "plain_text",
    "text": "Generate plan"
  },
  "close": {
    "type": "plain_text",
    "text": "Cancel"
  },
  "blocks": [
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": "Define your research methodology, timeline, and session details. This info will auto-fill participant outreach messages."
        }
      ]
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📂 Study*"
      }
    },
    {
      "type": "input",
      "block_id": "study_folder_block",
      "label": {
        "type": "plain_text",
        "text": "Research study folder"
      },
      "hint": {
        "type": "plain_text",
        "text": "Auto-populated from study"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "study_folder_input",
        "initial_value": "{{study_name}}"
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📁 Basic information*"
      }
    },
    {
      "type": "input",
      "block_id": "product_area_block",
      "label": {
        "type": "plain_text",
        "text": "Product / feature area *"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "product_area_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., Health & Benefits Mobile App"
        }
      }
    },
    {
      "type": "input",
      "block_id": "study_title_block",
      "label": {
        "type": "plain_text",
        "text": "Study title *"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "study_title_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., Claims Status Navigation Usability Study"
        }
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*🎯 Research context*"
      }
    },
    {
      "type": "input",
      "block_id": "decision_block",
      "label": {
        "type": "plain_text",
        "text": "What decision will this research inform? *"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "decision_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., Whether to redesign the claims navigation flow for Q4"
        },
        "multiline": true
      }
    },
    {
      "type": "input",
      "block_id": "research_goal_block",
      "label": {
        "type": "plain_text",
        "text": "Primary research goal *"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "research_goal_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., Identify navigation barriers preventing task completion"
        },
        "multiline": true
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*🔬 Methodology*"
      }
    },
    {
      "type": "input",
      "block_id": "methodology_block",
      "label": {
        "type": "plain_text",
        "text": "Methodology *"
      },
      "hint": {
        "type": "plain_text",
        "text": "Select all that apply"
      },
      "element": {
        "type": "multi_static_select",
        "action_id": "methodology_select",
        "placeholder": {
          "type": "plain_text",
          "text": "Select methods..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "Usability Testing"
            },
            "value": "usability_testing"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "User Interviews"
            },
            "value": "user_interviews"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Contextual Inquiry"
            },
            "value": "contextual_inquiry"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Concept Testing"
            },
            "value": "concept_testing"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Survey"
            },
            "value": "survey"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Card Sorting"
            },
            "value": "card_sorting"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Tree Testing"
            },
            "value": "tree_testing"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Diary Study"
            },
            "value": "diary_study"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "A/B Testing"
            },
            "value": "ab_testing"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Competitive Analysis"
            },
            "value": "competitive_analysis"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "Mixed Methods"
            },
            "value": "mixed_methods"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*👥 Participants*"
      }
    },
    {
      "type": "input",
      "block_id": "target_participants_block",
      "label": {
        "type": "plain_text",
        "text": "Target participants *"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "target_participants_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., Veterans who have used the mobile app in the past 90 days"
        },
        "multiline": true
      }
    },
    {
      "type": "input",
      "block_id": "num_participants_block",
      "label": {
        "type": "plain_text",
        "text": "Number of participants *"
      },
      "element": {
        "type": "static_select",
        "action_id": "num_participants_select",
        "placeholder": {
          "type": "plain_text",
          "text": "Select..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "5-6 participants"
            },
            "value": "5-6"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "8-10 participants"
            },
            "value": "8-10"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "12-15 participants"
            },
            "value": "12-15"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "15+ participants"
            },
            "value": "15+"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*⏱️ Session settings*"
      }
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": "Used to auto-fill participant outreach messages"
        }
      ]
    },
    {
      "type": "input",
      "block_id": "session_duration_block",
      "label": {
        "type": "plain_text",
        "text": "Session duration *"
      },
      "element": {
        "type": "static_select",
        "action_id": "session_duration_select",
        "placeholder": {
          "type": "plain_text",
          "text": "Select..."
        },
        "initial_option": {
          "text": {
            "type": "plain_text",
            "text": "45 minutes"
          },
          "value": "45"
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "30 minutes"
            },
            "value": "30"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "45 minutes"
            },
            "value": "45"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "60 minutes"
            },
            "value": "60"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "90 minutes"
            },
            "value": "90"
          }
        ]
      }
    },
    {
      "type": "input",
      "block_id": "incentive_block",
      "label": {
        "type": "plain_text",
        "text": "Participant incentive *"
      },
      "element": {
        "type": "static_select",
        "action_id": "incentive_select",
        "placeholder": {
          "type": "plain_text",
          "text": "Select..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "No incentive"
            },
            "value": "none"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "$25"
            },
            "value": "25"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "$50"
            },
            "value": "50"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "$75"
            },
            "value": "75"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "$100"
            },
            "value": "100"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "$125"
            },
            "value": "125"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "$150"
            },
            "value": "150"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📅 Timeline*"
      }
    },
    {
      "type": "input",
      "block_id": "start_date_block",
      "label": {
        "type": "plain_text",
        "text": "Start date *"
      },
      "element": {
        "type": "datepicker",
        "action_id": "start_date_picker",
        "placeholder": {
          "type": "plain_text",
          "text": "Select a date"
        }
      }
    },
    {
      "type": "input",
      "block_id": "timeline_block",
      "label": {
        "type": "plain_text",
        "text": "Timeline *"
      },
      "element": {
        "type": "radio_buttons",
        "action_id": "timeline_radio",
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "🚀 Rush (2-3 weeks)"
            },
            "value": "rush"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "📋 Standard (4-6 weeks)"
            },
            "value": "standard"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "📊 Extended (8+ weeks)"
            },
            "value": "extended"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*👤 Research team*"
      }
    },
    {
      "type": "input",
      "block_id": "lead_researcher_block",
      "label": {
        "type": "plain_text",
        "text": "Lead researcher"
      },
      "hint": {
        "type": "plain_text",
        "text": "Auto-synced from your Slack profile"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "lead_researcher_input",
        "initial_value": "{{lead_researcher}}"
      }
    },
    {
      "type": "input",
      "block_id": "researcher_title_block",
      "label": {
        "type": "plain_text",
        "text": "Title *"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "researcher_title_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., UX Researcher"
        }
      }
    },
    {
      "type": "input",
      "block_id": "researcher_email_block",
      "label": {
        "type": "plain_text",
        "text": "Contact email *"
      },
      "hint": {
        "type": "plain_text",
        "text": "For participant communication"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "researcher_email_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., jordan.researcher@va.gov"
        }
      }
    },
    {
      "type": "input",
      "block_id": "team_office_block",
      "optional": true,
      "label": {
        "type": "plain_text",
        "text": "Team / office"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "team_office_input",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., OCTO Health & Benefits"
        }
      }
    }
  ]
}
