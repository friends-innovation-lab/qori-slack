{
  "type": "modal",
  "callback_id": "reports_modal",
  "title": {
    "type": "plain_text",
    "text": "Research reports"
  },
  "submit": {
    "type": "plain_text",
    "text": "Generate report"
  },
  "close": {
    "type": "plain_text",
    "text": "Cancel"
  },
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📂 Research study*"
      }
    },
    {
      "type": "input",
      "block_id": "study_select_block",
      "label": {
        "type": "plain_text",
        "text": "Study *"
      },
      "element": {
        "type": "static_select",
        "action_id": "study_id",
        "placeholder": {
          "type": "plain_text",
          "text": "Select study..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_1_name}}"
            },
            "value": "{{study_1_id}}"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_2_name}}"
            },
            "value": "{{study_2_id}}"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📊 Select a report type*"
      }
    },
    {
      "type": "actions",
      "block_id": "report_type_block",
      "elements": [
        {
          "type": "button",
          "action_id": "select_research_readout",
          "text": {
            "type": "plain_text",
            "text": "Research Readout"
          }
        },
        {
          "type": "button",
          "action_id": "select_targeted_readouts",
          "text": {
            "type": "plain_text",
            "text": "Targeted Readouts"
          }
        },
        {
          "type": "button",
          "action_id": "select_github_issues",
          "text": {
            "type": "plain_text",
            "text": "GitHub Issues"
          }
        }
      ]
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": "📄 *Research Readout* — Complete findings and insights\n🎯 *Targeted Readouts* — Audience-specific summaries\n🐙 *GitHub Issues* — Create issues from findings"
        }
      ]
    }
  ]
}
