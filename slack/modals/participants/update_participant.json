{
  "type": "modal",
  "callback_id": "update_participant_modal",
  "title": {
    "type": "plain_text",
    "text": "Update participant"
  },
  "submit": {
    "type": "plain_text",
    "text": "Update"
  },
  "close": {
    "type": "plain_text",
    "text": "Cancel"
  },
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📂 Research study*"
      }
    },
    {
      "type": "actions",
      "block_id": "study_select_block",
      "elements": [
        {
          "type": "static_select",
          "action_id": "study_selection",
          "placeholder": {
            "type": "plain_text",
            "text": "Select a study..."
          },
          "options": [
            {
              "text": {
                "type": "plain_text",
                "text": "{{study_1_name}}"
              },
              "value": "{{study_1_id}}"
            },
            {
              "text": {
                "type": "plain_text",
                "text": "{{study_2_name}}"
              },
              "value": "{{study_2_id}}"
            }
          ]
        }
      ]
    },
    {
      "type": "actions",
      "block_id": "load_participants_block",
      "elements": [
        {
          "type": "button",
          "action_id": "load_participants",
          "text": {
            "type": "plain_text",
            "text": "Load participants"
          },
          "style": "primary"
        }
      ]
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*👤 Participant*"
      }
    },
    {
      "type": "input",
      "block_id": "participant_select_block",
      "label": {
        "type": "plain_text",
        "text": "Select participant *"
      },
      "hint": {
        "type": "plain_text",
        "text": "Load participants first to see options"
      },
      "element": {
        "type": "static_select",
        "action_id": "participant_selection",
        "placeholder": {
          "type": "plain_text",
          "text": "Select participant..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "Load participants first"
            },
            "value": "placeholder"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*🔄 Update*"
      }
    },
    {
      "type": "input",
      "block_id": "new_status_block",
      "label": {
        "type": "plain_text",
        "text": "New status *"
      },
      "element": {
        "type": "static_select",
        "action_id": "new_status",
        "placeholder": {
          "type": "plain_text",
          "text": "Select..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "✅ Confirmed (session scheduled)"
            },
            "value": "confirmed"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "⏳ Pending (awaiting response)"
            },
            "value": "pending"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "🔄 Rescheduling needed"
            },
            "value": "rescheduling"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "🔔 Backup participant"
            },
            "value": "backup"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "🎉 Completed"
            },
            "value": "completed"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "❌ Canceled / no-show"
            },
            "value": "canceled"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "🚫 Disqualified"
            },
            "value": "disqualified"
          }
        ]
      }
    },
    {
      "type": "input",
      "block_id": "update_notes_block",
      "optional": true,
      "label": {
        "type": "plain_text",
        "text": "Update notes"
      },
      "hint": {
        "type": "plain_text",
        "text": "Add context for this status change"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "status_notes",
        "placeholder": {
          "type": "plain_text",
          "text": "e.g., Rescheduled to next week, participant requested morning time"
        },
        "multiline": true
      }
    }
  ]
}
