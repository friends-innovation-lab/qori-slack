{
  "type": "modal",
  "callback_id": "synthesis",
  "title": {
    "type": "plain_text",
    "text": "Synthesize study"
  },
  "submit": {
    "type": "plain_text",
    "text": "Run analysis"
  },
  "close": {
    "type": "plain_text",
    "text": "Cancel"
  },
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📂 Study*"
      }
    },
    {
      "type": "input",
      "block_id": "study_select_block",
      "label": {
        "type": "plain_text",
        "text": "Study *"
      },
      "element": {
        "type": "static_select",
        "action_id": "study_id",
        "placeholder": {
          "type": "plain_text",
          "text": "Select study..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_1_name}}"
            },
            "value": "{{study_1_id}}"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_2_name}}"
            },
            "value": "{{study_2_id}}"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "input",
      "block_id": "analysis_method_block",
      "label": {
        "type": "plain_text",
        "text": "Analysis method *"
      },
      "element": {
        "type": "radio_buttons",
        "action_id": "analysis_method",
        "options": [
          {
            "text": {
              "type": "mrkdwn",
              "text": "*🗂️ Affinity mapping* — Cluster findings into themes"
            },
            "value": "affinity_mapping"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*🗺️ Journey mapping* — Visualize user experience over time"
            },
            "value": "journey_mapping"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*👤 Persona generation* — Create user archetypes from patterns"
            },
            "value": "persona_generation"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*🎯 Jobs to be done* — Extract user goals and motivations"
            },
            "value": "jtbd"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*⚠️ Usability issues* — Prioritize problems by severity"
            },
            "value": "usability_issues"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*💡 Design opportunities* — Generate HMW statements"
            },
            "value": "design_opportunities"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*🔧 Service blueprint* — Map frontstage and backstage"
            },
            "value": "service_blueprint"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📄 Data sources*"
      }
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": "Select files to include in analysis."
        }
      ]
    },
    {
      "type": "actions",
      "block_id": "load_files_block",
      "elements": [
        {
          "type": "button",
          "action_id": "load_files",
          "text": {
            "type": "plain_text",
            "text": "Load files"
          },
          "style": "primary"
        }
      ]
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*Session Summaries*"
      }
    },
    {
      "type": "input",
      "block_id": "session_summaries_block",
      "optional": true,
      "label": {
        "type": "plain_text",
        "text": "Select summaries"
      },
      "element": {
        "type": "checkboxes",
        "action_id": "session_summaries",
        "options": [
          {
            "text": {
              "type": "mrkdwn",
              "text": "*PT001-session-summary.md*\n2026-01-15"
            },
            "value": "{{summary_1_path}}"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*PT002-session-summary.md*\n2026-01-16"
            },
            "value": "{{summary_2_path}}"
          }
        ]
      }
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*Transcripts*"
      }
    },
    {
      "type": "input",
      "block_id": "transcripts_block",
      "optional": true,
      "label": {
        "type": "plain_text",
        "text": "Select transcripts"
      },
      "element": {
        "type": "checkboxes",
        "action_id": "transcripts",
        "options": [
          {
            "text": {
              "type": "mrkdwn",
              "text": "*pt001-coded-transcript.md*\n2026-01-15"
            },
            "value": "{{transcript_1_path}}"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*pt002-coded-transcript.md*\n2026-01-16"
            },
            "value": "{{transcript_2_path}}"
          }
        ]
      }
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*Stakeholder Interviews*"
      }
    },
    {
      "type": "input",
      "block_id": "stakeholder_block",
      "optional": true,
      "label": {
        "type": "plain_text",
        "text": "Select stakeholder files"
      },
      "element": {
        "type": "checkboxes",
        "action_id": "stakeholder_files",
        "options": [
          {
            "text": {
              "type": "mrkdwn",
              "text": "*stakeholder-synthesis.md*\n2026-01-10"
            },
            "value": "{{stakeholder_1_path}}"
          }
        ]
      }
    }
  ]
}
