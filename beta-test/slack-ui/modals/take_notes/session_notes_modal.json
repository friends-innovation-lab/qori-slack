{
  "type": "modal",
  "callback_id": "session_notes_modal",
  "title": {
    "type": "plain_text",
    "text": "Session notes"
  },
  "submit": {
    "type": "plain_text",
    "text": "Save notes"
  },
  "close": {
    "type": "plain_text",
    "text": "Back"
  },
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📅 Session*"
      }
    },
    {
      "type": "input",
      "block_id": "session_id_block",
      "label": {
        "type": "plain_text",
        "text": "Session *"
      },
      "element": {
        "type": "static_select",
        "action_id": "session_id",
        "placeholder": {
          "type": "plain_text",
          "text": "Select session..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "{{session_1_id}} — {{session_1_participant}} ({{session_1_date}})"
            },
            "value": "{{session_1_id}}"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "{{session_2_id}} — {{session_2_participant}} ({{session_2_date}})"
            },
            "value": "{{session_2_id}}"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": "💡 *Tips for better notes:*\n• Quote reactions: `\"This is confusing\"`\n• Note timestamps: `Minute 5: User struggled`\n• Describe tasks: `Task 1 - Find benefits (3 min)`\n• Flag issues: `VoiceOver didn't announce button`\n• Capture emotions: `User sighed, frustrated`"
        }
      ]
    },
    {
      "type": "input",
      "block_id": "raw_notes_block",
      "label": {
        "type": "plain_text",
        "text": "Your notes *"
      },
      "hint": {
        "type": "plain_text",
        "text": "Write freely — AI will organize into structured sections"
      },
      "element": {
        "type": "plain_text_input",
        "action_id": "raw_notes",
        "placeholder": {
          "type": "plain_text",
          "text": "Type or paste your session observations..."
        },
        "multiline": true
      }
    }
  ]
}
