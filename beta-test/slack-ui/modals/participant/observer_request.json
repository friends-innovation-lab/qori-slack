{
	"type": "modal",
	"callback_id": "observer_request_modal",
	"title": {
		"type": "plain_text",
		"text": "Observer request"
	},
	"submit": {
		"type": "plain_text",
		"text": "Request"
	},
	"close": {
		"type": "plain_text",
		"text": "Cancel"
	},
	"blocks": [
		{
			"type": "section",
			"text": {
				"type": "mrkdwn",
				"text": "*👤 Requesting user*"
			}
		},
		{
			"type": "context",
			"elements": [
				{
					"type": "mrkdwn",
					"text": "{{user_name}}\nYour Slack profile"
				}
			]
		},
		{
			"type": "divider"
		},
		{
			"type": "section",
			"text": {
				"type": "mrkdwn",
				"text": "*📅 Select session*"
			}
		},
		{
			"type": "input",
			"block_id": "session_select_block",
			"label": {
				"type": "plain_text",
				"text": "Session to observe *"
			},
			"element": {
				"type": "static_select",
				"action_id": "session_id",
				"placeholder": {
					"type": "plain_text",
					"text": "Select session..."
				},
				"options": [
					{
						"text": {
							"type": "plain_text",
							"text": "{{session_1_date}} {{session_1_time}} — {{session_1_participant}}"
						},
						"value": "{{session_1_id}}"
					},
					{
						"text": {
							"type": "plain_text",
							"text": "{{session_2_date}} {{session_2_time}} — {{session_2_participant}}"
						},
						"value": "{{session_2_id}}"
					}
				]
			}
		},
		{
			"type": "divider"
		},
		{
			"type": "input",
			"block_id": "observer_role_block",
			"label": {
				"type": "plain_text",
				"text": "Observer role *"
			},
			"element": {
				"type": "radio_buttons",
				"action_id": "observer_role",
				"options": [
					{
						"text": {
							"type": "plain_text",
							"text": "📝 Note-taker"
						},
						"value": "note_taker"
					},
					{
						"text": {
							"type": "plain_text",
							"text": "👁️ Silent observer"
						},
						"value": "silent_observer"
					},
					{
						"text": {
							"type": "plain_text",
							"text": "📊 PM observer"
						},
						"value": "pm_observer"
					},
					{
						"text": {
							"type": "plain_text",
							"text": "🏛️ Stakeholder"
						},
						"value": "stakeholder"
					}
				]
			}
		}
	]
}
