{
  "type": "modal",
  "callback_id": "analyze_notes_modal",
  "title": {
    "type": "plain_text",
    "text": "Analyze notes"
  },
  "submit": {
    "type": "plain_text",
    "text": "Analyze"
  },
  "close": {
    "type": "plain_text",
    "text": "Cancel"
  },
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📂 Research study*"
      }
    },
    {
      "type": "input",
      "block_id": "study_select_block",
      "label": {
        "type": "plain_text",
        "text": "Study *"
      },
      "element": {
        "type": "static_select",
        "action_id": "study_id",
        "placeholder": {
          "type": "plain_text",
          "text": "Select study..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_1_name}}"
            },
            "value": "{{study_1_id}}"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_2_name}}"
            },
            "value": "{{study_2_id}}"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📅 Select session*"
      }
    },
    {
      "type": "input",
      "block_id": "session_select_block",
      "label": {
        "type": "plain_text",
        "text": "Session *"
      },
      "element": {
        "type": "static_select",
        "action_id": "session_id",
        "placeholder": {
          "type": "plain_text",
          "text": "Select session..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "{{session_1_participant}} — {{session_1_date}}"
            },
            "value": "{{session_1_id}}"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "{{session_2_participant}} — {{session_2_date}}"
            },
            "value": "{{session_2_id}}"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📝 Select notes to analyze*"
      }
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": "Choose note files to generate a session summary with key pain points, quotes, and observations."
        }
      ]
    },
    {
      "type": "section",
      "block_id": "note_count_block",
      "text": {
        "type": "mrkdwn",
        "text": "*Available Note Files* ✅ {{note_count}} files found"
      }
    },
    {
      "type": "input",
      "block_id": "selected_notes_block",
      "label": {
        "type": "plain_text",
        "text": "Note files"
      },
      "element": {
        "type": "checkboxes",
        "action_id": "selected_notes",
        "options": [
          {
            "text": {
              "type": "mrkdwn",
              "text": "*session-notes_lapedra_January 28, 2026_17:24.md*\nPT001 • 2026-02-16 • 12:00"
            },
            "value": "{{note_1_path}}"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*session-notes_lapedra_January 26, 2026_23:31.md*\nPT001 • 2026-02-16 • 12:00"
            },
            "value": "{{note_2_path}}"
          },
          {
            "text": {
              "type": "mrkdwn",
              "text": "*pt001-coded-transcript-analysis.md*\nPT001 • 2026-01-12 • 10:00"
            },
            "value": "{{note_3_path}}"
          }
        ]
      }
    }
  ]
}
