# ============================================
# QORI SLACK AI BOT - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# For local development:
DB_HOST=localhost
# For Docker:
# DB_HOST=postgres

DB_PORT=5432
DB_NAME=qori_dev
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_DIALECT=postgres

# ============================================
# Redis Configuration
# ============================================
# For local development:
REDIS_HOST=localhost
# For Docker:
# REDIS_HOST=redis

REDIS_PORT=6379
REDIS_URI=redis://localhost:6379
# For Docker:
# REDIS_URI=redis://redis:6379

# ============================================
# Slack Configuration
# ============================================
# Get these from: https://api.slack.com/apps
# 1. Create a Slack app
# 2. OAuth & Permissions → Install to workspace → Copy Bot Token
# 3. Basic Information → Copy Signing Secret
# 4. App-Level Tokens → Create token with connections:write scope

SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# ============================================
# GitHub Configuration
# ============================================
# Get token from: GitHub → Settings → Developer settings → Personal access tokens
# Required scopes: repo, workflow

GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=your-repo-name

# ============================================
# AI/LLM Configuration
# ============================================
# Anthropic (Claude) - Required
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Optional Anthropic settings (defaults shown)
ANTHROPIC_MODEL_NAME=claude-sonnet-4-20250514
ANTHROPIC_TEMPERATURE=0.4
ANTHROPIC_MAX_TOKENS=3000

# ============================================
# RAG Pipeline (Optional — disabled for alpha)
# ============================================
# These are only needed if you want to enable the RAG-based study search
# features (/civicmind ask-study, /ask-study, /run-template).
# If all three are set, the RAG pipeline initializes automatically on boot.
# If any are missing, the server boots fine and RAG commands return a
# "not available yet" message.

# OpenAI - used for gpt-4o-mini + embeddings in the RAG pipeline
# Get from: https://platform.openai.com/
# OPENAI_API_KEY=sk-your-openai-key-here

# Supabase - vector store for document search
# Get from: https://supabase.com/ → Your project → Settings → API
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ============================================
# Security & Authentication
# ============================================
# Generate a secure random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=your-random-secret-key-here

# ============================================
# Monitoring & Error Tracking (Optional)
# ============================================
# Get DSN from: https://sentry.io/
# Only required for production
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# Email/SMTP Configuration (Optional)
# ============================================
# Only required if using email features
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGIN=http://localhost:8000

# ============================================
# Research Team Channel (Optional)
# ============================================
# Slack channel ID for research team notifications
RESEARCH_TEAM_CHANNEL_ID=C1234567890
