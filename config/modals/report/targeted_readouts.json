{
  "type": "modal",
  "callback_id": "targeted_readouts",
  "title": {
    "type": "plain_text",
    "text": "Targeted readouts"
  },
  "submit": {
    "type": "plain_text",
    "text": "Generate readout"
  },
  "close": {
    "type": "plain_text",
    "text": "Back"
  },
  "blocks": [
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*📂 Research study*"
      }
    },
    {
      "type": "input",
      "block_id": "study_select_block",
      "label": {
        "type": "plain_text",
        "text": "Study *"
      },
      "element": {
        "type": "static_select",
        "action_id": "study_id",
        "placeholder": {
          "type": "plain_text",
          "text": "Select study..."
        },
        "options": [
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_1_name}}"
            },
            "value": "{{study_1_id}}"
          },
          {
            "text": {
              "type": "plain_text",
              "text": "{{study_2_name}}"
            },
            "value": "{{study_2_id}}"
          }
        ]
      }
    },
    {
      "type": "divider"
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*🎯 Target audience*"
      }
    },
    {
      "type": "input",
      "block_id": "target_audience_block",
      "label": {
        "type": "plain_text",
        "text": "Audience *"
      },
      "element": {
        "type": "static_select",
        "action_id": "target_audience",
        "placeholder": {
          "type": "plain_text",
          "text": "Select audience..."
        },
        "option_groups": [
          {
            "label": {
              "type": "plain_text",
              "text": "Teams"
            },
            "options": [
              {
                "text": {
                  "type": "plain_text",
                  "text": "🎨 Design Team"
                },
                "value": "design"
              },
              {
                "text": {
                  "type": "plain_text",
                  "text": "⚙️ Engineering Team"
                },
                "value": "engineering"
              },
              {
                "text": {
                  "type": "plain_text",
                  "text": "✍️ Content Team"
                },
                "value": "content"
              },
              {
                "text": {
                  "type": "plain_text",
                  "text": "📋 Product Team"
                },
                "value": "product"
              },
              {
                "text": {
                  "type": "plain_text",
                  "text": "♿ Accessibility Team"
                },
                "value": "accessibility"
              }
            ]
          },
          {
            "label": {
              "type": "plain_text",
              "text": "Leadership & Stakeholders"
            },
            "options": [
              {
                "text": {
                  "type": "plain_text",
                  "text": "👔 Executive Leadership"
                },
                "value": "executive_leadership"
              },
              {
                "text": {
                  "type": "plain_text",
                  "text": "📊 Product Owner"
                },
                "value": "product_leadership"
              },
              {
                "text": {
                  "type": "plain_text",
                  "text": "🏛️ Congressional Briefing"
                },
                "value": "congressional_briefing"
              }
            ]
          }
        ]
      }
    }
  ]
}
